<Window
    x:Class="HuaweiWmiControl.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:HuaweiWmiControl"
    xmlns:models="using:HuaweiWmiControl.Models"
    xmlns:controls="using:HuaweiWmiControl.Controls"
    mc:Ignorable="d"
    Title="华为笔记本调控工具">

    <Grid x:Name="RootGrid" RowDefinitions="Auto,*" Loaded="RootGrid_Loaded">
        <!-- 标题栏：32px 高度，遵循 Windows 11 设计规范 -->
        <Grid x:Name="AppTitleBar" Grid.Row="0" Height="32"
              VerticalAlignment="Top" Background="Transparent">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <!-- 图标 16x16 + 标题，左侧 16px -->
            <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center" Margin="16,0,0,0" Spacing="12">
                <FontIcon Glyph="&#xE7EC;" FontSize="16"
                          Foreground="{ThemeResource SystemAccentColor}"/>
                <TextBlock Text="华为笔记本调控工具"
                           Style="{StaticResource CaptionTextBlockStyle}"
                           VerticalAlignment="Center"/>
            </StackPanel>

            <!-- 状态区域：ProgressRing + 协议信息，居中排列 -->
            <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Center"
                        VerticalAlignment="Center" Spacing="8">
                <ProgressRing Width="16" Height="16"
                              IsActive="{x:Bind ViewModel.IsLoading, Mode=OneWay}"
                              Visibility="{x:Bind ViewModel.IsLoading, Mode=OneWay}"/>
                <TextBlock Text="{x:Bind ViewModel.StatusMessage, Mode=OneWay}"
                           Style="{StaticResource CaptionTextBlockStyle}"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                           VerticalAlignment="Center"
                           TextTrimming="CharacterEllipsis"
                           MaxWidth="400"/>
            </StackPanel>

            <!-- 右侧预留空间，避免与窗口按钮重叠 -->
            <Rectangle Grid.Column="2" Width="140"/>
        </Grid>

        <!-- NavigationView -->
        <NavigationView x:Name="NavView" Grid.Row="1"
                        PaneDisplayMode="LeftCompact"
                        IsSettingsVisible="True"
                        OpenPaneLength="220" CompactPaneLength="48"
                        SelectionChanged="NavView_SelectionChanged">

            <NavigationView.MenuItems>
                <NavigationViewItem Icon="View" Tag="sensors" Content="传感器"/>
                <NavigationViewItem Icon="Setting" Tag="battery" Content="电池保护"
                    Visibility="{x:Bind ViewModel.BatteryVisibility, Mode=OneWay}"/>
                <NavigationViewItem Icon="Keyboard" Tag="fnlock" Content="Fn-Lock"
                    Visibility="{x:Bind ViewModel.FnLockVisibility, Mode=OneWay}"/>
                <NavigationViewItem Icon="BrowsePhotos" Tag="keyboard" Content="键盘背光"
                    Visibility="{x:Bind ViewModel.KeyboardVisibility, Mode=OneWay}"/>
                <NavigationViewItem Icon="SetTile" Tag="smartcharge" Content="智能充电"
                    Visibility="{x:Bind ViewModel.SmartChargeVisibility, Mode=OneWay}"/>
                <NavigationViewItem Icon="Permissions" Tag="powerunlock" Content="电源解锁"
                    Visibility="{x:Bind ViewModel.PowerUnlockVisibility, Mode=OneWay}"/>
                <NavigationViewItem Icon="Microphone" Tag="micled" Content="麦克风 LED"
                    Visibility="{x:Bind ViewModel.MicLedVisibility, Mode=OneWay}"/>
            </NavigationView.MenuItems>

            <ScrollViewer x:Name="ContentScroll">
                <StackPanel x:Name="ContentRoot" Spacing="24" Margin="32,24">

                    <!-- Status InfoBar -->
                    <InfoBar x:Name="GlobalInfoBar"
                             IsOpen="{x:Bind ViewModel.IsStatusOpen, Mode=OneWay}"
                             Severity="{x:Bind ViewModel.StatusSeverity, Mode=OneWay}"
                             Message="{x:Bind ViewModel.StatusMessage, Mode=OneWay}"
                             IsClosable="False"/>

                    <!-- 传感器（首页） -->
                    <controls:FeatureCard x:Name="SectionSensors"
                        Title="传感器"
                        Description="温度传感器和风扇转速"
                        Visibility="Collapsed">
                        <StackPanel Spacing="16">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <Button Content="刷新"
                                        Command="{x:Bind ViewModel.Sensors.RefreshCommand}"/>
                                <Button Content="{x:Bind ViewModel.Sensors.AutoRefreshLabel, Mode=OneWay}"
                                        Command="{x:Bind ViewModel.Sensors.ToggleAutoRefreshCommand}"/>
                            </StackPanel>
                            <Grid ColumnDefinitions="200,160">
                                <TextBlock Grid.Column="0" Text="名称" FontWeight="SemiBold"/>
                                <TextBlock Grid.Column="1" Text="数值" FontWeight="SemiBold"/>
                            </Grid>
                            <ListView x:Name="sensorList"
                                      ItemsSource="{x:Bind ViewModel.Sensors.Items, Mode=OneWay}"
                                      HorizontalAlignment="Stretch">
                                <ListView.ItemTemplate>
                                    <DataTemplate x:DataType="models:SensorItem">
                                        <Grid ColumnDefinitions="200,160" Padding="0,4">
                                            <TextBlock Grid.Column="0" Text="{x:Bind Name, Mode=OneWay}"/>
                                            <TextBlock Grid.Column="1" Text="{x:Bind Value, Mode=OneWay}"/>
                                        </Grid>
                                    </DataTemplate>
                                </ListView.ItemTemplate>
                            </ListView>
                        </StackPanel>
                    </controls:FeatureCard>

                    <!-- 电池保护 -->
                    <controls:FeatureCard x:Name="SectionBattery"
                        Title="电池保护"
                        Description="通过限制充电区间来延长电池寿命"
                        Visibility="Visible">
                        <StackPanel Spacing="16">
                            <StackPanel Orientation="Horizontal" Spacing="24">
                                <NumberBox x:Name="batStart" Header="充电起始 (%)" Minimum="0" Maximum="100"
                                           Value="{x:Bind ViewModel.Battery.Start, Mode=TwoWay}"
                                           Width="180" SpinButtonPlacementMode="Inline"/>
                                <NumberBox x:Name="batEnd" Header="充电上限 (%)" Minimum="0" Maximum="100"
                                           Value="{x:Bind ViewModel.Battery.End, Mode=TwoWay}"
                                           Width="180" SpinButtonPlacementMode="Inline"/>
                            </StackPanel>
                            <CheckBox x:Name="batReset" Content="关闭前先清零阈值（MACH-WX9 兼容）"
                                      IsChecked="{x:Bind ViewModel.Battery.Reset, Mode=TwoWay}"/>
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <Button Content="读取" Command="{x:Bind ViewModel.Battery.ReadCommand}"/>
                                <Button Content="应用" Command="{x:Bind ViewModel.Battery.ApplyCommand}"/>
                                <Button Content="关闭充电控制"
                                        Command="{x:Bind ViewModel.Battery.DisableCommand}"
                                        Background="{ThemeResource SystemAccentColor}"
                                        Foreground="White"/>
                            </StackPanel>
                        </StackPanel>
                    </controls:FeatureCard>

                    <!-- Fn-Lock -->
                    <controls:FeatureCard x:Name="SectionFnLock"
                        Title="Fn-Lock"
                        Description="控制 F1-F12 键模式"
                        Visibility="Collapsed">
                        <StackPanel Spacing="16">
                            <ToggleSwitch x:Name="fnLock" Header="启用 Fn-Lock"
                                          IsOn="{x:Bind ViewModel.FnLock.State, Mode=TwoWay}"/>
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <Button Content="读取" Command="{x:Bind ViewModel.FnLock.ReadCommand}"/>
                                <Button Content="应用" Command="{x:Bind ViewModel.FnLock.ApplyCommand}"/>
                            </StackPanel>
                        </StackPanel>
                    </controls:FeatureCard>

                    <!-- 键盘背光 -->
                    <controls:FeatureCard x:Name="SectionKeyboard"
                        Title="键盘背光"
                        Description="亮度每 0.5 秒自动刷新"
                        Visibility="Collapsed">
                        <StackPanel Spacing="16">
                            <StackPanel Orientation="Horizontal" Spacing="16">
                                <TextBlock Text="背光级别" Style="{StaticResource BodyStrongTextBlockStyle}"
                                           VerticalAlignment="Center"/>
                                <TextBlock Text="{x:Bind ViewModel.Keyboard.BrightnessText, Mode=OneWay}"
                                           FontSize="28" FontWeight="SemiBold"
                                           VerticalAlignment="Center"
                                           Foreground="{ThemeResource SystemAccentColor}"/>
                            </StackPanel>
                            <NumberBox x:Name="kbdTimeout" Header="熄灭时间（秒, 0=常亮）"
                                       Minimum="0" Maximum="65535"
                                       Value="{x:Bind ViewModel.Keyboard.Timeout, Mode=TwoWay}"
                                       Width="320" SpinButtonPlacementMode="Inline"/>
                            <Button Content="应用超时"
                                    Command="{x:Bind ViewModel.Keyboard.ApplyCommand}"
                                    HorizontalAlignment="Left"/>
                        </StackPanel>
                    </controls:FeatureCard>

                    <!-- 智能充电 -->
                    <controls:FeatureCard x:Name="SectionSmartCharge"
                        Title="智能充电"
                        Description="华为私有充电模式"
                        Visibility="Collapsed">
                        <StackPanel Spacing="16">
                            <StackPanel Orientation="Horizontal" Spacing="24">
                                <NumberBox x:Name="scMode" Header="模式" Minimum="0" Maximum="3"
                                           Value="{x:Bind ViewModel.SmartCharge.Mode, Mode=TwoWay}"
                                           Width="160" SpinButtonPlacementMode="Inline"/>
                                <NumberBox x:Name="scUnknown" Header="未知参数" Minimum="0" Maximum="2"
                                           Value="{x:Bind ViewModel.SmartCharge.Unknown, Mode=TwoWay}"
                                           Width="220" SpinButtonPlacementMode="Inline"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Spacing="24">
                                <NumberBox x:Name="scStart" Header="起始 (%)" Minimum="0" Maximum="100"
                                           Value="{x:Bind ViewModel.SmartCharge.Start, Mode=TwoWay}"
                                           Width="160" SpinButtonPlacementMode="Inline"/>
                                <NumberBox x:Name="scEnd" Header="上限 (%)" Minimum="0" Maximum="100"
                                           Value="{x:Bind ViewModel.SmartCharge.End, Mode=TwoWay}"
                                           Width="160" SpinButtonPlacementMode="Inline"/>
                            </StackPanel>
                            <NumberBox x:Name="scParam" Header="附加参数" Minimum="0" Maximum="2"
                                       Value="{x:Bind ViewModel.SmartCharge.Param, Mode=TwoWay}"
                                       Width="220" SpinButtonPlacementMode="Inline"/>
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <Button Content="读取" Command="{x:Bind ViewModel.SmartCharge.ReadCommand}"/>
                                <Button Content="应用" Command="{x:Bind ViewModel.SmartCharge.ApplyCommand}"/>
                            </StackPanel>
                        </StackPanel>
                    </controls:FeatureCard>

                    <!-- 电源解锁 -->
                    <controls:FeatureCard x:Name="SectionPowerUnlock"
                        Title="电源解锁"
                        Description="解除电源/性能限制（Fn+P）"
                        Visibility="Collapsed">
                        <StackPanel Spacing="16">
                            <ToggleSwitch x:Name="pwrUnlock" Header="启用电源解锁"
                                          IsOn="{x:Bind ViewModel.PowerUnlock.State, Mode=TwoWay}"/>
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <Button Content="读取" Command="{x:Bind ViewModel.PowerUnlock.ReadCommand}"/>
                                <Button Content="应用" Command="{x:Bind ViewModel.PowerUnlock.ApplyCommand}"/>
                            </StackPanel>
                        </StackPanel>
                    </controls:FeatureCard>

                    <!-- 麦克风 LED -->
                    <controls:FeatureCard x:Name="SectionMicLed"
                        Title="麦克风静音指示灯"
                        Description="部分机型由系统驱动"
                        Visibility="Collapsed">
                        <StackPanel Spacing="16">
                            <ToggleSwitch x:Name="micLed" Header="点亮麦克风静音指示灯"
                                          IsOn="{x:Bind ViewModel.MicMuteLed.State, Mode=TwoWay}"/>
                            <Button Content="应用" Command="{x:Bind ViewModel.MicMuteLed.ApplyCommand}"
                                    HorizontalAlignment="Left"/>
                        </StackPanel>
                    </controls:FeatureCard>

                    <!-- 设置 -->
                    <StackPanel x:Name="SectionSettings" Spacing="16" Visibility="Collapsed">
                        <StackPanel.Resources>
                            <Style x:Key="SettingsCardStyle" TargetType="Border">
                                <Setter Property="Background" Value="{ThemeResource CardBackgroundFillColorDefaultBrush}"/>
                                <Setter Property="BorderBrush" Value="{ThemeResource CardStrokeColorDefaultBrush}"/>
                                <Setter Property="BorderThickness" Value="1"/>
                                <Setter Property="CornerRadius" Value="8"/>
                            </Style>
                        </StackPanel.Resources>

                        <TextBlock Text="设置" Style="{StaticResource TitleTextBlockStyle}"/>

                        <!-- 外观 -->
                        <Border Style="{StaticResource SettingsCardStyle}">
                            <StackPanel Spacing="12" Padding="24">
                                <TextBlock Text="外观" Style="{StaticResource BodyStrongTextBlockStyle}"/>
                                <ComboBox x:Name="ThemeSelector" Header="主题" Width="220"
                                          SelectedIndex="0"
                                          SelectionChanged="ThemeSelector_SelectionChanged">
                                    <x:String>跟随系统</x:String>
                                    <x:String>亮色</x:String>
                                    <x:String>暗色</x:String>
                                </ComboBox>
                            </StackPanel>
                        </Border>

                        <!-- 选项卡管理 -->
                        <Border Style="{StaticResource SettingsCardStyle}">
                            <StackPanel Spacing="12" Padding="24">
                                <TextBlock Text="选项卡管理" Style="{StaticResource BodyStrongTextBlockStyle}"/>
                                <TextBlock Text="关闭不需要的选项卡以简化导航"
                                           Style="{StaticResource BodyTextBlockStyle}"
                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                <StackPanel Spacing="8">
                                    <ToggleSwitch Header="电池保护"
                                                  IsOn="{x:Bind ViewModel.BatteryVisible, Mode=TwoWay}"/>
                                    <ToggleSwitch Header="Fn-Lock"
                                                  IsOn="{x:Bind ViewModel.FnLockVisible, Mode=TwoWay}"/>
                                    <ToggleSwitch Header="键盘背光"
                                                  IsOn="{x:Bind ViewModel.KeyboardVisible, Mode=TwoWay}"/>
                                    <ToggleSwitch Header="智能充电"
                                                  IsOn="{x:Bind ViewModel.SmartChargeVisible, Mode=TwoWay}"/>
                                    <ToggleSwitch Header="电源解锁"
                                                  IsOn="{x:Bind ViewModel.PowerUnlockVisible, Mode=TwoWay}"/>
                                    <ToggleSwitch Header="麦克风 LED"
                                                  IsOn="{x:Bind ViewModel.MicLedVisible, Mode=TwoWay}"/>
                                    <ToggleSwitch Header="传感器" IsEnabled="False" IsOn="True"/>
                                </StackPanel>
                                <Button Content="全部关闭（保留传感器）"
                                        Command="{x:Bind ViewModel.HideAllExceptSensorsCommand}"
                                        HorizontalAlignment="Left"/>
                            </StackPanel>
                        </Border>

                        <!-- 连接信息 -->
                        <Border Style="{StaticResource SettingsCardStyle}">
                            <StackPanel Spacing="8" Padding="24">
                                <TextBlock Text="连接信息" Style="{StaticResource BodyStrongTextBlockStyle}"/>
                                <TextBlock Text="{x:Bind ViewModel.StatusMessage, Mode=OneWay}"
                                           Style="{StaticResource BodyTextBlockStyle}"
                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                                <TextBlock Style="{StaticResource CaptionTextBlockStyle}"
                                           Foreground="{ThemeResource TextFillColorTertiaryBrush}">
                                    通过 WMI (root/wmi) 与华为 ACPI 固件通信，需要管理员权限。
                                </TextBlock>
                            </StackPanel>
                        </Border>

                        <!-- 诊断日志 -->
                        <Border Style="{StaticResource SettingsCardStyle}">
                            <StackPanel Spacing="8" Padding="24">
                                <StackPanel Orientation="Horizontal" Spacing="12">
                                    <TextBlock Text="诊断日志" Style="{StaticResource BodyStrongTextBlockStyle}"
                                               VerticalAlignment="Center"/>
                                    <Button Content="清空" Click="ClearLog_Click" FontSize="12"
                                            Padding="8,2" VerticalAlignment="Center"/>
                                </StackPanel>
                                <TextBox MinHeight="240"
                                         IsReadOnly="True" AcceptsReturn="True" TextWrapping="Wrap"
                                         Text="{x:Bind ViewModel.LogText, Mode=OneWay}"
                                         ScrollViewer.VerticalScrollBarVisibility="Auto"
                                         FontFamily="Consolas" FontSize="12"
                                         HorizontalAlignment="Stretch"
                                         AutomationProperties.Name="诊断日志"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>

                </StackPanel>
            </ScrollViewer>
        </NavigationView>

    </Grid>
</Window>
